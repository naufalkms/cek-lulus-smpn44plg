{
    "version": 2,
    "builds": [
        {
            "src": "public/index.php",
            "use": "vercel-php"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "public/index.php"
        }
    ],
    "functions": {
        "public/index.php": {
            "excludeFiles": "{node_modules,storage/framework/views,storage/logs,*.zip,*.rar}/**"
        }
    }
}